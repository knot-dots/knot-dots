# Copy this file to .env and fill in secrets for local development.
# NEVER commit real credentials.

# --- Queue (Scaleway SQS-compatible) ---
INDEXING_QUEUE_URL=https://sqs.scaleway.com/your-queue-url
INDEXING_QUEUE_REGION=fr-par
INDEXING_QUEUE_ACCESS_KEY=changeme_access_key
INDEXING_QUEUE_SECRET_KEY=changeme_secret_key
# Optional custom endpoint (leave blank if default)
INDEXING_QUEUE_ENDPOINT=

# Poll interval between empty receives (ms)
INDEXING_WORKER_POLL_INTERVAL_MS=2000

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX_ALIAS=containers
ELASTICSEARCH_DEBUG=false

# --- Other application vars (add as needed) ---
PUBLIC_BASE_URL=http://localhost:5173

# Add any additional secrets (SMTP, etc.) here, keeping real values out of version control.